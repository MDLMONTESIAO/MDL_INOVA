  "html": "<u>INTRO: <i>Bm</i> <i>A</i> <i>Em</i> <i>Bm</i> <i>D</i> <i>A</i>\r\n\r\n</u><u><i>G</i>                                          <i>A</i>\r\n</u><u>SE EM MEIO A UMA BATALHA\r\n\r\n</u><u>ALGUÉM ME FERIR\r\n</u><u><i>G</i>                                         <i>A</i>\r\n</u><u>OU EM MEIO <i>A</i> UM DESERTO\r\n\r\n</u><u><i>EM</i> ME PERDER\r\n</u><u>                    <i>Bm</i>                        <i>A</i>                          <i>G</i>\r\n</u><u>DEUS VAI ME SURPREENDER MAIS UMA VEZ\r\n</u><u>                        <i>D/F#</i>                                 <i>Em</i>\r\n</u><u>COM SEU MILAGRE, ELE ESTÁ COMIGO\r\n</u><u>                                                   <i>A</i>\r\n</u><u>SE NO MAIS PROFUNDO ABISMO\r\n</u><u>                              <i>D</i>      <i>Em</i>\r\n</u><u>EU ME ENCONTRAR, MESMO ASSIM\r\n</u><u>              <i>Bm</i>\r\n</u><u>A TUA MÃO ME ALCANÇARÁ\r\n</u><u><i>Em</i>                                                <i>D/F#</i>\r\n</u><u>E QUANDO A NOITE ME CERCAR\r\n</u><u>                     <i>G</i>                         <i>A4</i>       <i>A9</i>\r\n</u><u>O TEU FAROL VAI ME GUIAR\r\n\r\n</u><u>                              <i>D</i>                                   <i>A</i>\r\n</u><u>DEUS ESTÁ COMIGO, EU SINTO NO AR\r\n</u><u>                     <i>Bm</i>                          <i>G</i>\r\n</u><u>É COMO O VENTO <i>A</i> ME TOCAR\r\n</u><u>                         <i>D</i>                                      <i>A</i>\r\n</u><u>PASSEIA COMIGO, CONVERSA COMIGO\r\n</u><u>                        <i>Bm</i>                                     <i>G</i>\r\n</u><u>REVELA SEGREDOS QUE SÓ NELE HÁ\r\n</u><u>         <i>D/F#</i>                   <i>Em</i>\r\n</u><u>ME PÕE EM SEUS PLANOS\r\n</u><u>                                 <i>B/D#</i>\r\n</u><u>SOU PARTE DOS SONHOS\r\n</u><u>                                    <i>G/D</i>\r\n</u><u>DOS SONHOS PERFEITOS\r\n</u><u>                                    <i>B4</i>